generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role { student admin }
enum UnlockType { location manual quest }
enum ContentType { photo message badge clue }

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  passwordHash String
  universityId String
  role        Role     @default(student)
  createdAt   DateTime @default(now())

  university  University @relation(fields: [universityId], references: [id])
  progress    ExplorationProgress[]
  unlocks     UnlockedContent[]
  captures    PhotoCapture[]
}

model University {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  centerLat  Float
  centerLng  Float
  mapBounds  Json
  createdAt  DateTime @default(now())

  users      User[]
  zones      CampusZone[]
  pois       PointOfInterest[]
  quests     Quest[]
}

model CampusZone {
  id                String   @id @default(cuid())
  universityId      String
  name              String
  description       String
  polygonGeoJson    Json
  revealRadiusMeters Int
  unlockType        UnlockType
  createdAt         DateTime @default(now())

  university University @relation(fields: [universityId], references: [id])
  pois       PointOfInterest[]
  progress   ExplorationProgress[]
}

model PointOfInterest {
  id                String   @id @default(cuid())
  universityId      String
  zoneId            String
  name              String
  description       String
  lat               Float
  lng               Float
  category          String
  imageUrl          String?
  message           String
  unlockRadiusMeters Int
  createdAt         DateTime @default(now())

  university University @relation(fields: [universityId], references: [id])
  zone       CampusZone @relation(fields: [zoneId], references: [id])
  unlocks    UnlockedContent[]
  captures   PhotoCapture[]
}

model ExplorationProgress {
  id              String   @id @default(cuid())
  userId          String
  zoneId          String
  discoveredAt    DateTime @default(now())
  percentExplored Float

  user User @relation(fields: [userId], references: [id])
  zone CampusZone @relation(fields: [zoneId], references: [id])

  @@unique([userId, zoneId])
}

model UnlockedContent {
  id              String   @id @default(cuid())
  userId          String
  pointOfInterestId String
  contentType     ContentType
  unlockedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pointOfInterest PointOfInterest @relation(fields: [pointOfInterestId], references: [id])

  @@unique([userId, pointOfInterestId, contentType])
}

model PhotoCapture {
  id              String   @id @default(cuid())
  userId          String
  pointOfInterestId String
  imageUrl        String
  caption         String?
  lat             Float
  lng             Float
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pointOfInterest PointOfInterest @relation(fields: [pointOfInterestId], references: [id])
}

model Quest {
  id            String   @id @default(cuid())
  universityId  String
  title         String
  description   String
  requiredPoiIds String[]
  rewardBadge   String
  createdAt     DateTime @default(now())

  university University @relation(fields: [universityId], references: [id])
}
